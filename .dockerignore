# 版本控制
.git/
.gitignore

# 数据库和数据文件
data/
app.db
*.db
*.db3
app/backups/

# Python缓存
__pycache__/
*/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# 环境和配置文件
.env
.env.*
*.env
.flaskenv
instance/
venv/
.venv/

# 文档和示例文件
README.md
CHANGELOG.md
LICENSE
app/static/vendor/README.md
app/static/vendor/base.html.example
app/static/vendor/implementation.*

# 系统文件
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# IDE配置
.vscode/
.idea/
*.sublime-*
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 日志文件
*.log
logs/

# 运行期上传资源，不打进镜像
app/static/uploads/

# Docker相关
.dockerignore
docker-compose.yml
docker-compose.prod.yml
docker-compose.override.yml

# 临时文件
*.tmp
*.bak
*.swp
*~
.*.swp

# 文档目录（不需要在镜像中）
docs/
img/

# 参考项目（不需要在镜像中）
PixelPunk/
config/

# 测试和开发脚本（运行时不需要）
tests/
test_*.py
*_test.py
batch_generate_vectors.py
init_db.py
start_qdrant.bat
stop_qdrant.bat

# 数据库迁移（Docker部署使用 db.create_all()，不需要 migrations）
migrations/ 
